    <effect id="Bodymat-fx" name="Bodymat">
      <profile_COMMON>
        <newparam sid="Soldier12_Body_Diffuse-surface">
          <surface type="2D">
            <init_from>Soldier12_Body_Diffuse-image</init_from>
          </surface>
        </newparam>
        <newparam sid="Soldier12_Body_Diffuse-sampler">
          <sampler2D>
            <source>Soldier12_Body_Diffuse-surface</source>
            <minfilter>LINEAR</minfilter>
            <magfilter>LINEAR</magfilter>
          </sampler2D>
        </newparam>
        <newparam sid="Soldier12_Body_Specular-surface">
          <surface type="2D">
            <init_from>Soldier12_Body_Specular-image</init_from>
          </surface>
        </newparam>
        <newparam sid="Soldier12_Body_Specular-sampler">
          <sampler2D>
            <source>Soldier12_Body_Specular-surface</source>
            <minfilter>LINEAR</minfilter>
            <magfilter>LINEAR</magfilter>
          </sampler2D>
        </newparam>
        <newparam sid="Soldier12_Body_Opacity-surface">
          <surface type="2D">
            <init_from>Soldier12_Body_Opacity-image</init_from>
          </surface>
        </newparam>
        <newparam sid="Soldier12_Body_Opacity-sampler">
          <sampler2D>
            <source>Soldier12_Body_Opacity-surface</source>
            <minfilter>LINEAR</minfilter>
            <magfilter>LINEAR</magfilter>
          </sampler2D>
        </newparam>
        <newparam sid="Soldier12_Body_Normal-surface">
          <surface type="2D">
            <init_from>Soldier12_Body_Normal-image</init_from>
          </surface>
        </newparam>
        <newparam sid="Soldier12_Body_Normal-sampler">
          <sampler2D>
            <source>Soldier12_Body_Normal-surface</source>
            <minfilter>LINEAR</minfilter>
            <magfilter>LINEAR</magfilter>
          </sampler2D>
        </newparam>
        <newparam sid="Soldier12_Body_Gloss-surface">
          <surface type="2D">
            <init_from>Soldier12_Body_Gloss-image</init_from>
          </surface>
        </newparam>
        <newparam sid="Soldier12_Body_Gloss-sampler">
          <sampler2D>
            <source>Soldier12_Body_Gloss-surface</source>
            <minfilter>LINEAR</minfilter>
            <magfilter>LINEAR</magfilter>
          </sampler2D>
        </newparam>
        <technique sid="standard">
          <phong>
            <emission>
              <color sid="emission">0.000000  0.000000 0.000000 1.000000</color>
            </emission>
            <ambient>
              <color sid="ambient">0.000000  0.000000 0.000000 1.000000</color>
            </ambient>
            <diffuse>
              <texture texture="Soldier12_Body_Diffuse-sampler" texcoord="CHANNEL0">
                <extra>
                  <technique profile="MAYA">
                    <wrapU sid="wrapU0">TRUE</wrapU>
                    <wrapV sid="wrapV0">TRUE</wrapV>
                    <blend_mode>ADD</blend_mode>
                  </technique>
                </extra>
                <extra type="texture_offset">
                  <technique profile="ADOBE">
                    <offsets>
                      <offsetu>0.000000</offsetu>
                      <offsetu>0.000000</offsetu>
                      <offsetv>0.000000</offsetv>
                      <scaleu>1.000000</scaleu>
                      <scalev>1.000000</scalev>
                      <angle>0.000000</angle>
                    </offsets>
                  </technique>
                </extra>
              </texture>
            </diffuse>
            <specular>
              <texture texture="Soldier12_Body_Specular-sampler" texcoord="CHANNEL0">
                <extra>
                  <technique profile="MAYA">
                    <wrapU sid="wrapU0">TRUE</wrapU>
                    <wrapV sid="wrapV0">TRUE</wrapV>
                    <blend_mode>ADD</blend_mode>
                  </technique>
                </extra>
                <extra type="texture_offset">
                  <technique profile="ADOBE">
                    <offsets>
                      <offsetu>0.000000</offsetu>
                      <offsetu>0.000000</offsetu>
                      <offsetv>0.000000</offsetv>
                      <scaleu>1.000000</scaleu>
                      <scalev>1.000000</scalev>
                      <angle>0.000000</angle>
                    </offsets>
                  </technique>
                </extra>
              </texture>
            </specular>
            <shininess>
              <float sid="shininess">20.000000</float>
              <texture texture="Soldier12_Body_Gloss-sampler" texcoord="CHANNEL0">
                <extra>
                  <technique profile="MAYA">
                    <wrapU sid="wrapU0">TRUE</wrapU>
                    <wrapV sid="wrapV0">TRUE</wrapV>
                    <blend_mode>ADD</blend_mode>
                  </technique>
                </extra>
                <extra type="texture_offset">
                  <technique profile="ADOBE">
                    <offsets>
                      <offsetu>0.000000</offsetu>
                      <offsetu>0.000000</offsetu>
                      <offsetv>0.000000</offsetv>
                      <scaleu>1.000000</scaleu>
                      <scalev>1.000000</scalev>
                      <angle>0.000000</angle>
                    </offsets>
                  </technique>
                </extra>
              </texture>
            </shininess>
            <reflective>
              <color sid="reflective">0.000000  0.000000 0.000000 1.000000</color>
            </reflective>
            <reflectivity>
              <float sid="reflectivity">0.040000</float>
            </reflectivity>
            <transparent opaque="RGB_ZERO">
              <texture texture="Soldier12_Body_Opacity-sampler" texcoord="CHANNEL0">
                <extra>
                  <technique profile="MAYA">
                    <wrapU sid="wrapU0">TRUE</wrapU>
                    <wrapV sid="wrapV0">TRUE</wrapV>
                    <blend_mode>ADD</blend_mode>
                  </technique>
                </extra>
                <extra type="texture_offset">
                  <technique profile="ADOBE">
                    <offsets>
                      <offsetu>0.000000</offsetu>
                      <offsetu>0.000000</offsetu>
                      <offsetv>0.000000</offsetv>
                      <scaleu>1.000000</scaleu>
                      <scalev>1.000000</scalev>
                      <angle>0.000000</angle>
                    </offsets>
                  </technique>
                </extra>
              </texture>
            </transparent>
            <transparency>
              <float sid="transparency">1.000000</float>
            </transparency>
          </phong>
          <extra>
            <technique profile="FCOLLADA">
              <displacement>
                <texture texture="Soldier12_Body_Normal-sampler" texcoord="CHANNEL0">
                  <extra>
                    <technique profile="MAYA">
                      <wrapU sid="wrapU0">TRUE</wrapU>
                      <wrapV sid="wrapV0">TRUE</wrapV>
                      <blend_mode>ADD</blend_mode>
                    </technique>
                  </extra>
                  <extra type="texture_offset">
                    <technique profile="ADOBE">
                      <offsets>
                        <offsetu>0.000000</offsetu>
                        <offsetu>0.000000</offsetu>
                        <offsetv>0.000000</offsetv>
                        <scaleu>1.000000</scaleu>
                        <scalev>1.000000</scalev>
                        <angle>0.000000</angle>
                      </offsets>
                    </technique>
                  </extra>
                  <extra>
                    <technique profile="MAX3D">
                      <amount>0.000000</amount>
                    </technique>
                  </extra>
                </texture>
              </displacement>
            </technique>
          </extra>
        </technique>
      </profile_COMMON>
    </effect>
