<?xml version="1.0"?>
<model>
  <name>Explosion</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <author>
    <name>leonciohermosillo</name>
    <email>lhermosillo@pheratech.com</email>
  </author>
  <description>
    Fire/smoke explosion effect built from a gz-sim particle_emitter.
    Self-contained (locally generated sprite). Needs the
    gz::sim::systems::ParticleEmitter system plugin in the world, and
    GPU rendering (particles only show in the GUI, not headless).
  </description>
</model>
