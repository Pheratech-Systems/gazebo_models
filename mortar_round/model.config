<?xml version="1.0"?>
<model>
  <name>Mortar Round</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>

  <author>
    <name>leonciohermosillo</name>
    <email>lhermosillo@pheratech.com</email>
  </author>

  <description>
    A 120 mm-class mortar bomb built from SDF primitives (ogive body,
    tail boom, cruciform fins). Dynamic rigid body with inertia, so it
    can be dropped/thrown. Stands nose-up along +Z.
  </description>
</model>
